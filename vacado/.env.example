# ─── Core ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── Database ───────────────────────────────────────────
# Use connection_limit to bound the Prisma pool when not fronting with pgBouncer
DATABASE_URL=postgresql://vacado:vacado@postgres:5432/vacado?schema=public&connection_limit=10

# ─── Redis (BullMQ + cache) ─────────────────────────────
REDIS_URL=redis://redis:6379

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT=http://localhost:4000/api/channels/callback

# ─── AI ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...

# ─── YouTube Data API v3 ────────────────────────────────
YOUTUBE_API_KEY=...

# ─── Stripe ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_starter_id
STRIPE_PRICE_PRO=price_pro_id
STRIPE_PRICE_AGENCY=price_agency_id

# ─── Storage (AWS S3 or Cloudflare R2) ──────────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
S3_BUCKET=vacado-media
# Optional: set for Cloudflare R2 / S3-compatible endpoints
S3_ENDPOINT=
S3_PUBLIC_URL=https://vacado-media.s3.amazonaws.com

# ─── Email (SendGrid via Nodemailer) ────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=Vacado <no-reply@vacado.app>
